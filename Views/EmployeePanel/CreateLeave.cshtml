@model Leave
@{
    ViewData["Title"] = "İzin Talebi Oluştur";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-calendar-plus"></i>
        </span> Yeni İzin Talebi
    </h3>
    <nav aria-label="breadcrumb">
        <ul class="breadcrumb">
            <li class="breadcrumb-item active" aria-current="page">
                <span>İzin Formu</span>
            </li>
        </ul>
    </nav>
</div>

<div class="row">
    <div class="col-md-8 grid-margin stretch-card mx-auto">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="card-title text-primary mb-4">İzin Talep Formunu Doldurun</h4>
                
                <form class="forms-sample" asp-action="CreateLeave" asp-controller="EmployeePanel" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="form-group mb-3">
                        <label for="LeaveTypeId" class="form-label text-muted">İzin Türü</label>
                        <select name="LeaveTypeId" class="form-select border-primary-subtle" required>
                            <option value="">İzin türü seçin...</option>
                            @if (ViewBag.LeaveTypes != null)
                            {
                                @foreach (var type in ViewBag.LeaveTypes)
                                {
                                    <option value="@type.LeaveTypeId">@type.LeaveTypeName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="form-group">
                                <label for="StartDate" class="form-label text-muted">Başlangıç Tarihi</label>
                                <input type="date" name="StartDate" class="form-control border-primary-subtle" required />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-group">
                                <label for="EndDate" class="form-label text-muted">Bitiş Tarihi</label>
                                <input type="date" name="EndDate" class="form-control border-primary-subtle" required />
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label for="Reason" class="form-label text-muted">İzin Nedeni / Açıklama</label>
                        <textarea name="Reason" class="form-control border-primary-subtle" rows="4" placeholder="İzin gerekçenizi buraya yazın..." required></textarea>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="/EmployeePanel/Leaves" class="btn btn-light">İptal Et</a>
                        <button type="submit" class="btn btn-gradient-primary btn-icon-text">
                            <i class="mdi mdi-send btn-icon-prepend"></i> Talebi Gönder
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
