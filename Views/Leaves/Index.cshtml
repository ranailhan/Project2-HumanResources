@model ICollection<Leave>
@{
    ViewData["Title"] = "İzin Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h4 class="card-title">İzin Listesi</h4>
<br />

<div class="d-flex justify-content-start align-items-center mb-3 gap-2">
    <div class="search-field d-none d-md-block">
        <form class="d-flex align-items-center h-100 gap-2" action="/Leaves/Index" method="get">
            <select name="searchField" class="form-select form-select-sm" style="width: auto;">
                <option value="">Filtreli Ara</option>
                <option value="id">İzin ID</option>
                <option value="name">Çalışan Adı</option>
                <option value="leaveType">İzin Türü</option>
                <option value="startDate">Başlangıç Tarihi</option>
                <option value="endDate">Bitiş Tarihi</option>
                <option value="reason">Sebep</option>
                <option value="status">Durum</option>
            </select>

            <div class="input-group input-group-sm">
                <span class="input-group-text border-0 bg-transparent">
                    <i class="mdi mdi-magnify"></i>
                </span>
                <input type="text" name="search" class="form-control bg-transparent border-0"
                       placeholder="Ara...">
            </div>

            <button type="submit" class="btn btn-sm btn-primary">Ara</button>
        </form>
    </div>
    <a href="/Leaves/Create" class="btn btn-gradient-primary btn-icon-text">Yeni İzin Ekle</a>
    <a href="/Leaves/Index" class="btn btn-gradient-info btn-icon-text"> Listele </a>
</div>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Çalışan Adı</th>
                <th>İzin Türü</th>
                <th>Başlangıç Tarihi</th>
                <th>Bitiş Tarihi</th>
                <th>Neden</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var leaf in Model)
            {
                <tr>
                    <td>@leaf.Employee?.FirstName @leaf.Employee?.LastName</td>
                    <td>@leaf.LeaveType?.LeaveTypeName</td>
                    <td>@leaf.StartDate?.ToString("dd.MM.yyyy")</td>
                    <td>@leaf.EndDate?.ToString("dd.MM.yyyy")</td>
                    <td>@(string.IsNullOrEmpty(leaf.Reason) ? "-" : leaf.Reason)</td>
                    <td>
                        @if (leaf.Status == "Approved")
                        {
                            <span class="badge badge-gradient-success">Onaylı</span>
                        }
                        else if (leaf.Status == "Pending")
                        {
                            <span class="badge badge-gradient-warning">Beklemede</span>
                        }
                        else if (leaf.Status == "Rejected")
                        {
                            <span class="badge badge-gradient-danger">Reddedildi</span>
                        }
                        else
                        {
                            <span class="badge badge-gradient-info">@leaf.Status</span>
                        }
                    </td>
                    <td>
                        <a href="/Leaves/Edit/@leaf.LeaveId" class="btn btn-sm btn-gradient-warning">
                            <i class="mdi mdi-pencil"></i>
                        </a>
                        <a href="/Leaves/Delete/@leaf.LeaveId" class="btn btn-sm btn-gradient-danger">
                            <i class="mdi mdi-delete"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>