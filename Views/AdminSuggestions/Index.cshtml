@model ICollection<WishSuggestion>
@{
    ViewData["Title"] = "Dilek & İstekler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-comment-account-outline"></i>
        </span> Çalışan Dilek & İstekleri
    </h3>
    <nav aria-label="breadcrumb">
        <ul class="breadcrumb">
            <li class="breadcrumb-item active" aria-current="page">
                <span>Geri Bildirim Takip Listesi</span>
            </li>
        </ul>
    </nav>
</div>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                    <div class="search-field">
                        <form class="d-flex align-items-center h-100 gap-2" action="/AdminSuggestions/Index" method="get">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text border-0 bg-transparent">
                                    <i class="mdi mdi-magnify"></i>
                                </span>
                                <input type="text" name="search" class="form-control bg-transparent border-0 border-bottom border-primary"
                                       placeholder="Başlık, içerik veya çalışan ara...">
                            </div>
                            <button type="submit" class="btn btn-sm btn-gradient-primary">Filtrele</button>
                            <a href="/AdminSuggestions/Index" class="btn btn-sm btn-light">Temizle</a>
                        </form>
                    </div>
                    <div class="gap-2 d-flex">
                        <button onclick="exportTableToExcel('adminSuggestionsTable', 'Calisan_Dilek_Istekleri')" class="btn btn-sm btn-gradient-success btn-icon-text">
                            <i class="mdi mdi-file-excel btn-icon-prepend"></i> Excel
                        </button>
                        <button onclick="exportTableToPDF('adminSuggestionsTable', 'Calisan_Dilek_Istekleri', 'Çalışan Dilek ve İstekleri')" class="btn btn-sm btn-gradient-danger btn-icon-text">
                            <i class="mdi mdi-file-pdf btn-icon-prepend"></i> PDF
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="adminSuggestionsTable">
                        <thead>
                            <tr class="table-info text-dark">
                                <th> Çalışan Ad Soyad </th>
                                <th> Departman </th>
                                <th> Konu / Başlık </th>
                                <th> Dilek / İstek Detayı </th>
                                <th> Gönderim Tarihi </th>
                                <th> Durum </th>
                                <th> İşlemler </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var wish in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>
                                            @if (wish.Employee != null)
                                            {
                                                @wish.Employee.FirstName @wish.Employee.LastName
                                            }
                                            else
                                            {
                                                <span class="text-muted">Bilinmeyen Çalışan</span>
                                            }
                                        </strong>
                                    </td>
                                    <td>@(wish.Employee?.Department?.DepartmentName ?? "-")</td>
                                    <td><strong>@wish.Title</strong></td>
                                    <td style="max-width: 350px; white-space: normal; word-break: break-all;">
                                        <div>@wish.Content</div>
                                        @if (!string.IsNullOrEmpty(wish.AdminReply))
                                        {
                                            <div class="mt-2 text-primary small font-weight-bold" style="padding-left: 10px; border-left: 2px solid #9a55ff;">
                                                <i class="mdi mdi-reply"></i> Yanıtınız: <span class="text-muted font-weight-normal">@wish.AdminReply</span>
                                            </div>
                                        }
                                    </td>
                                    <td>@wish.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (wish.Status == "Cevaplandı")
                                        {
                                            <span class="badge badge-gradient-success">Cevaplandı</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-gradient-warning">Beklemede</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="/AdminSuggestions/Reply/@wish.Id" class="btn btn-sm btn-gradient-primary btn-icon-text" style="padding: 5px 10px;">
                                            <i class="mdi mdi-reply btn-icon-prepend"></i> Yanıtla
                                        </a>
                                    </td>
                                </tr>
                            }
                            @if (Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Herhangi bir dilek veya istek kaydı bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
