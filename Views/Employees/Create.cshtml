@model Employee
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h4 class="card-title">Yeni Çalışan Ekle</h4>
<br />

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <div class="form-group">
                        <label for="firstName">Ad</label>
                        <input type="text" class="form-control" id="firstName"
                               name="FirstName" placeholder="Adını girin" required>
                    </div>

                    <div class="form-group">
                        <label for="lastName">Soyad</label>
                        <input type="text" class="form-control" id="lastName"
                               name="LastName" placeholder="Soyadını girin" required>
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" class="form-control" id="email"
                               name="Email" placeholder="Email adresini girin">
                    </div>

                    <div class="form-group">
                        <label for="phone">Telefon Numarası</label>
                        <input type="text" class="form-control" id="phone"
                               name="Phone" placeholder="Telefon numarasını girin">
                    </div>

                    <div class="form-group">
                        <label for="hireDate">İşe Başlama Tarihi</label>
                        <input type="date" class="form-control" id="hireDate" name="HireDate">
                    </div>

                    <div class="form-group">
                        <label for="salary">Maaş</label>
                        <input type="text" class="form-control" id="salary"
                               name="Salary" placeholder="0.00" step="0.01">
                    </div>

                    <div class="form-group">
                        <label for="departmentId">Departman</label>
                        <select class="form-select" id="departmentId" name="DepartmentId" required>
                            <option value="">-- Seç --</option>
                            @foreach (var dept in ViewBag.Departments)
                            {
                                <option value="@dept.DepartmentId">@dept.DepartmentName</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="positionId">Pozisyon</label>
                        <select class="form-select" id="positionId" name="PositionId" required>
                            <option value="">-- Seç --</option>
                            @foreach (var pos in ViewBag.Positions)
                            {
                                <option value="@pos.PositionId">@pos.PositionName</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-gradient-primary me-2">Ekle</button>
                    <a href="/Employees/Index" class="btn btn-light">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>

