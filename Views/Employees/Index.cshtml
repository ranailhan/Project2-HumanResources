@model ICollection<Employee>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h4 class="card-title">Çalışan Listesi</h4>
<br />
<div class="d-flex justify-content-start align-items-center mb-3 gap-2">
    <div class="search-field d-none d-md-block">
        <form class="d-flex align-items-center h-100 gap-2" action="/Employees/Index" method="get">
            <select name="searchField" class="form-select form-select-sm" style="width: auto;">
                <option value="">Filtreli Ara</option>
                <option value="id">Çalışan ID</option>
                <option value="name">Ad</option>
                <option value="surname">Soyad</option>
                <option value="mail">Mail</option>
                <option value="number">Telefon</option>
                <option value="hireDate">İşe Giriş Tarihi</option>
                <option value="salary">Maaş</option>
                <option value="department">Departman</option>
                <option value="position">Pozisyon</option>
            </select>

            <div class="input-group input-group-sm">
                <span class="input-group-text border-0 bg-transparent">
                    <i class="mdi mdi-magnify"></i>
                </span>
                <input type="text" name="search" class="form-control bg-transparent border-0"
                       placeholder="Ara...">
            </div>

            <button type="submit" class="btn btn-sm btn-primary">Ara</button>
        </form>
    </div>
    <a href="/Employees/Create" class="btn btn-gradient-primary btn-icon-text"> Yeni Çalışan Ekle </a>
    <a href="/Employees/Index" class="btn btn-gradient-info btn-icon-text"> Listele </a>
    <button onclick="exportTableToExcel('employeesTable', 'Calisanlar_Listesi')" class="btn btn-gradient-success btn-icon-text">
        <i class="mdi mdi-file-excel btn-icon-prepend"></i> Excel
    </button>
    <button onclick="exportTableToPDF('employeesTable', 'Calisanlar_Listesi', 'Çalışan Listesi')" class="btn btn-gradient-danger btn-icon-text">
        <i class="mdi mdi-file-pdf btn-icon-prepend"></i> PDF
    </button>
</div>

<table class="table table-striped" id="employeesTable">
    <thead>
        <tr>
            <th> Ad Soyad </th>
            <th> Email  </th>
            <th> Telefon Numarası  </th>
            <th> İşe Başlangıç Tarihi </th>
            <th> Maaş </th>
            <th> Departman </th>
            <th> Pozisyon </th>
            <th> İşlemler </th>
        </tr>
    </thead>
    <tbody>

        @foreach (var employee in Model)
        {
            <tr>
                <td><strong>@employee.FirstName @employee.LastName</strong></td>
                <td>@employee.Email</td>
                <td>@employee.Phone</td>
                <td>@employee.HireDate?.ToString("dd.MM.yyyy") ?? "-"</td>
                <td>@employee.Salary?.ToString("C2") ?? "-"</td>
                <td>@employee.Department?.DepartmentName</td>
                <td>@employee.Position?.PositionName</td>
                <td>
                    <a href="/Employees/Edit/@employee.EmployeeId" class="edit-link"><i class="fa fa-pencil"></i></a>
                    <a href="/Employees/Delete/@employee.EmployeeId" class="delete-link"><i class="fa fa-trash-o"></i></a>
                </td>
            </tr>
        }

    </tbody>
</table>



