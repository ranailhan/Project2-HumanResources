@model ICollection<Employee>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h4 class="card-title">Çalışan Listesi</h4>
<br />
<div class="d-flex justify-content-start align-items-center mb-3 gap-2">
    <a href="/Employees/Create" class="btn btn-gradient-primary btn-icon-text"> Yeni Çalışan Ekle </a>
    <a href="/Employees/Index" class="btn btn-gradient-info btn-icon-text"> Listele </a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th> Ad Soyad </th>
            <th> Email  </th>
            <th> Telefon Numarası  </th>
            <th> İşe Başlangıç Tarihi </th>
            <th> Maaş </th>
            <th> Departman </th>
            <th> Pozisyon </th>
            <th> İşlemler </th>
        </tr>
    </thead>
    <tbody>

        @foreach (var employee in Model)
        {
            <tr>
                <td><strong>@employee.FirstName @employee.LastName</strong></td>
                <td>@employee.Email</td>
                <td>@employee.Phone</td>
                <td>@employee.HireDate?.ToString("dd.MM.yyyy") ?? "-"</td>
                <td>@employee.Salary?.ToString("C2") ?? "-"</td>
                <td>@employee.Department?.DepartmentName</td>
                <td>@employee.Position?.PositionName</td>
                <td>
                    <a href="/Employees/Edit/@employee.EmployeeId" class="edit-link"><i class="fa fa-pencil"></i></a>
                    <a href="/Employees/Delete/@employee.EmployeeId" class="delete-link"><i class="fa fa-trash-o"></i></a>
                </td>
            </tr>
        }

    </tbody>
</table>



