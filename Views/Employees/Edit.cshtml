@model Employee
@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h4 class="card-title">Çalışan Düzenle</h4><br />

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" name="EmployeeId" value="@Model.EmployeeId">

                    <div class="form-group">
                        <label for="firstName">Ad</label>
                        <input type="text" class="form-control" id="firstName" 
                               name="FirstName" value="@Model.FirstName" required>
                    </div>

                    <div class="form-group">
                        <label for="lastName">Soyad</label>
                        <input type="text" class="form-control" id="lastName" 
                               name="LastName" value="@Model.LastName" required>
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" class="form-control" id="email" 
                               name="Email" value="@Model.Email">
                    </div>

                    <div class="form-group">
                        <label for="phone">Telefon Numarası</label>
                        <input type="text" class="form-control" id="phone" 
                               name="Phone" value="@Model.Phone">
                    </div>

                    <div class="form-group">
                        <label for="hireDate">İşe Başlama Tarihi</label>
                        <input type="date" class="form-control" id="hireDate" 
                               name="HireDate" value="@Model.HireDate?.ToString("yyyy-MM-dd")">
                    </div>

                    <div class="form-group">
                        <label for="salary">Maaş</label>
                        <input type="text" class="form-control" id="salary" name="Salary" value="@Model.Salary">
                    </div>

                    <div class="form-group">
                        <label for="departmentId">Departman</label>
                        <select class="form-select" id="departmentId" name="DepartmentId" required>
                            <option value="">-- Seç --</option>
                            @foreach (var dept in ViewBag.Departments)
                            {
                                <option value="@dept.DepartmentId" selected="@(Model.DepartmentId == dept.DepartmentId)">
                                    @dept.DepartmentName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="positionId">Pozisyon</label>
                        <select class="form-select" id="positionId" name="PositionId" required>
                            <option value="">-- Seç --</option>
                            @foreach (var pos in ViewBag.Positions)
                            {
                                <option value="@pos.PositionId" selected="@(Model.PositionId == pos.PositionId)">
                                    @pos.PositionName
                                </option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-gradient-primary me-2">Güncelle</button>
                    <a href="/Employees/Index" class="btn btn-light">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>

