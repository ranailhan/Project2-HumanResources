@model Employee
@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h4 class="card-title">Çalışan Sil</h4>
<br />

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card border-danger">
            <div class="card-body">
                <h5 class="card-title text-danger mb-3">
                    <i class="mdi mdi-alert-circle me-2"></i> Emin misin?
                </h5>
                <p class="card-text mb-4">
                    <strong>@Model.FirstName @Model.LastName</strong> çalışanını silmek üzeresin. Bu işlem geri alınamaz.
                </p>

                <div class="alert alert-warning" role="alert">
                    <i class="mdi mdi-information-outline me-2"></i>
                    <strong>Çalışan Bilgileri:</strong>
                    <ul class="mb-0 mt-2">
                        <li>Email: @Model.Email</li>
                        <li>Telefon: @Model.Phone</li>
                        <li>Departman: @Model.Department?.DepartmentName</li>
                        <li>Pozisyon: @Model.Position?.PositionName</li>
                    </ul>
                </div>

                <form method="post">
                    <input type="hidden" name="EmployeeId" value="@Model.EmployeeId">

                    <button type="submit" class="btn btn-gradient-danger me-2">
                        <i class="mdi mdi-delete me-2"></i> Evet, Sil
                    </button>
                    <a href="/Employees/Index" class="btn btn-light">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>

