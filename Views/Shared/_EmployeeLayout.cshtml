<!DOCTYPE html>
<html lang="tr">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Çalışan Portalı - HR Portal</title>
    <!-- plugins:css -->
    <link rel="stylesheet" href="~/purple/src/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/purple/src/assets/vendors/ti-icons/css/themify-icons.css">
    <link rel="stylesheet" href="~/purple/src/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/purple/src/assets/vendors/font-awesome/css/font-awesome.min.css">
    <!-- endinject -->
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/purple/src/assets/vendors/font-awesome/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/purple/src/assets/vendors/bootstrap-datepicker/bootstrap-datepicker.min.css">
    <!-- End plugin css for this page -->
    <!-- Layout styles -->
    <link rel="stylesheet" href="~/purple/src/assets/css/style.css">
    <!-- End layout styles -->
    <link rel="shortcut icon" href="~/purple/src/assets/images/favicon.png" />
</head>
<body>
    <div class="container-scroller">
        <!-- navbar -->
        <nav class="navbar default-layout-navbar col-lg-12 col-12 p-0 fixed-top d-flex flex-row">
            <div class="text-center navbar-brand-wrapper d-flex align-items-center justify-content-start">
                <a class="navbar-brand brand-logo" href="/EmployeePanel/Index" style="text-decoration: none; padding-left: 20px;">
                    <span style="font-weight: 800; font-size: 1.5rem; background: linear-gradient(to right, #da8cff, #9a55ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: 1px;">HR PORTAL</span>
                </a>
                <a class="navbar-brand brand-logo-mini" href="/EmployeePanel/Index" style="text-decoration: none;">
                    <span style="font-weight: 900; font-size: 1.3rem; background: linear-gradient(to right, #da8cff, #9a55ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">HR</span>
                </a>
            </div>
            <div class="navbar-menu-wrapper d-flex align-items-stretch">
                <button class="navbar-toggler navbar-toggler align-self-center" type="button" data-toggle="minimize">
                    <span class="mdi mdi-menu"></span>
                </button>
                <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button" data-toggle="offcanvas">
                    <span class="mdi mdi-menu"></span>
                </button>
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <ul class="navbar-nav navbar-nav-right ms-auto">
                        <li class="nav-item nav-profile d-none d-lg-block">
                            <a class="nav-link" href="#" onclick="return false;">
                                <div class="nav-profile-text">
                                    <p class="mb-1 text-black font-weight-bold"><i class="mdi mdi-account-circle me-1 text-primary fs-5"></i> @User.Identity.Name</p>
                                </div>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Logout" title="Çıkış Yap">
                                <i class="mdi mdi-power text-danger fs-4"></i>
                            </a>
                        </li>
                    </ul>
                }
            </div>
        </nav>
        
        <div class="container-fluid page-body-wrapper">
            <!-- sidebar -->
            <nav class="sidebar sidebar-offcanvas" id="sidebar">
                <ul class="nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item nav-profile">
                            <a href="#" class="nav-link" onclick="return false;">
                                <div class="nav-profile-image" style="width: auto; height: auto;">
                                    <span class="mdi mdi-account-circle text-primary" style="font-size: 2.5rem; line-height: 1;"></span>
                                </div>
                                <div class="nav-profile-text d-flex flex-column ms-3">
                                    <span class="font-weight-bold mb-1" style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@User.Identity.Name?.Split('@')[0]</span>
                                    <span class="text-secondary text-small">Çalışan</span>
                                </div>
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link" href="/EmployeePanel/Index">
                            <span class="menu-title">Panelim</span>
                            <i class="mdi mdi-home menu-icon"></i>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/EmployeePanel/Leaves">
                            <span class="menu-title">İzinlerim</span>
                            <i class="mdi mdi-calendar-check menu-icon"></i>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/EmployeePanel/CreateLeave">
                            <span class="menu-title">İzin Talebi Oluştur</span>
                            <i class="mdi mdi-calendar-plus menu-icon"></i>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/EmployeePanel/Suggestions">
                            <span class="menu-title">Dilek & İstek Bildir</span>
                            <i class="mdi mdi-comment-account-outline menu-icon"></i>
                        </a>
                    </li>
                </ul>
            </nav>
            
            <!-- main-panel -->
            <div class="main-panel">
                <div class="content-wrapper">
                    @RenderBody()
                </div>
                <!-- footer -->
                <footer class="footer">
                    <div class="d-sm-flex justify-content-center justify-content-sm-between">
                        <span class="text-muted text-center text-sm-left d-block d-sm-inline-block">Copyright © 2023 <a href="https://www.bootstrapdash.com/" target="_blank">BootstrapDash</a>. All rights reserved.</span>
                        <span class="float-none float-sm-right d-block mt-1 mt-sm-0 text-center">Hand-crafted & made with <i class="mdi mdi-heart text-danger"></i></span>
                    </div>
                </footer>
            </div>
        </div>
    </div>
    
    <!-- plugins:js -->
    <script src="~/purple/src/assets/vendors/js/vendor.bundle.base.js"></script>
    <script src="~/purple/assets/js/off-canvas.js"></script>
    <script src="~/purple/src/assets/js/misc.js"></script>
    <script src="~/purple/src/assets/js/settings.js"></script>
    <script src="~/purple/src/assets/js/todolist.js"></script>
    <script src="~/purple/src/assets/js/jquery.cookie.js"></script>
    
    <!-- Excel & PDF Export Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
    <script src="~/js/excel-pdf-export.js"></script>
</body>
</html>
