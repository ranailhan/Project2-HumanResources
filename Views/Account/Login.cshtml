@model LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>İK Portalı - Giriş Yap</title>
    <link rel="stylesheet" href="~/purple/src/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/purple/src/assets/vendors/ti-icons/css/themify-icons.css">
    <link rel="stylesheet" href="~/purple/src/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/purple/src/assets/vendors/font-awesome/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/purple/src/assets/css/style.css">
    <link rel="shortcut icon" href="~/purple/src/assets/images/favicon.png" />
</head>
<body>
    <div class="container-scroller">
        <div class="container-fluid page-body-wrapper full-page-wrapper">
            <div class="content-wrapper d-flex align-items-center auth">
                <div class="row flex-grow">
                    <div class="col-lg-4 mx-auto">
                        <div class="auth-form-light text-left p-5 shadow-lg rounded">
                            <div class="brand-logo text-center mb-4">
                                <span style="font-weight: 800; font-size: 2.2rem; background: linear-gradient(to right, #da8cff, #9a55ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">HR PORTAL</span>
                            </div>
                            <h4 class="text-center">Hoş Geldiniz</h4>
                            <h6 class="font-weight-light text-center text-muted mb-4">Lütfen giriş yapın.</h6>
                            
                            <form class="pt-3" asp-action="Login" asp-controller="Account" method="post" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                
                                <div class="form-group mb-3">
                                    <label asp-for="Email" class="form-label text-muted"></label>
                                    <input asp-for="Email" class="form-control form-control-lg border-primary-subtle" placeholder="ornek@firma.com" />
                                    <span asp-validation-for="Email" class="text-danger mt-1 d-block"></span>
                                </div>
                                
                                <div class="form-group mb-3">
                                    <label asp-for="Password" class="form-label text-muted">Şifre</label>
                                    <input asp-for="Password" type="password" class="form-control form-control-lg border-primary-subtle" placeholder="Şifreniz" />
                                    <span asp-validation-for="Password" class="text-danger mt-1 d-block"></span>
                                </div>
                                
                                <div class="my-3 d-flex justify-content-between align-items-center">
                                    <div class="form-check">
                                        <label class="form-check-label text-muted">
                                            <input type="checkbox" asp-for="RememberMe" class="form-check-input"> Beni Hatırla
                                        </label>
                                    </div>
                                </div>
                                
                                <div class="mt-3 d-grid gap-2">
                                    <button type="submit" class="btn btn-block btn-gradient-primary btn-lg font-weight-medium auth-form-btn">GİRİŞ YAP</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="~/purple/src/assets/vendors/js/vendor.bundle.base.js"></script>
    <script src="~/purple/src/assets/js/off-canvas.js"></script>
    <script src="~/purple/src/assets/js/misc.js"></script>
</body>
</html>
